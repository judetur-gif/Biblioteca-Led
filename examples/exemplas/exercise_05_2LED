#include <Arduino.h>
#include <LED.h>

Led ledAzul(20);
Led ledVermelho(48);

void setup() 
{
 ledAzul.ligar();
 ledVermelho.piscar();
}

void loop() 
{
    ledAzul.update();
    ledVermelho.update();
}